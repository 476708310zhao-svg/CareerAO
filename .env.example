# Required for Gemini AI API calls.
# Used by /api/ai/polish-resume and /api/ai/interview-chat.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public URL where the app is hosted.
# AI Studio or Cloud Run style environments may inject this automatically.
APP_URL="https://www.zhiyincareer.com"

# Browser API base URL.
# In development, src/lib/api.ts uses an empty base so requests go to the local Express server.
# In production, keep this on the real domain unless deployment config provides a dedicated backend.
VITE_API_BASE_URL="https://www.zhiyincareer.com"

# Server-side proxy target for backend or mini-program APIs.
# If left as localhost:3001, /api/proxy/* returns a mock fallback signal.
REAL_API_BASE_URL="http://localhost:3001"
