{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "tsx server.ts",
    "build": "vite build",
    "prerender": "react-snap",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "guard": "node scripts/guard-sensitive-files.mjs",
    "verify": "npm run guard && npm run lint && npm run build"
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/",
      "/jobs",
      "/salary-insights",
      "/campus-calendar",
      "/campus-calendar/table",
      "/interview-experiences",
      "/blog",
      "/news",
      "/agency-evaluation",
      "/visa-policies",
      "/help-center",
      "/team",
      "/contact",
      "/privacy",
      "/terms"
    ],
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "waitFor": 500,
    "skipThirdPartyRequests": true,
    "removeScriptTags": false,
    "inlineCss": false,
    "minifyHtml": { "collapseWhitespace": false, "removeComments": false }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/multer": "^2.2.0",
    "@types/pdf-parse": "^1.1.5",
    "@vitejs/plugin-react": "^5.0.4",
    "d3-geo": "^3.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-is": "^19.2.6",
    "react-router-dom": "^7.14.0",
    "react-simple-maps": "^3.0.0",
    "react-snap": "^1.23.0",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/d3-geo": "^3.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react-simple-maps": "^3.0.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
